# Local development database settings. Do not use these values in production.
POSTGRES_DB=enterprise_audit
POSTGRES_USER=audit_app
POSTGRES_PASSWORD=audit_app_dev
DATABASE_URL=postgresql+psycopg://audit_app:audit_app_dev@db:5432/enterprise_audit

# Local model mode. The model cache is mounted at data/models.
MODEL_PROVIDER=local-hf
LOCAL_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
LOCAL_EMBEDDING_DIMENSIONS=512
MODEL_CACHE_DIR=/app/data/models

# Optional OpenAI-compatible settings for future LLM stages.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# MinIO object storage.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=audit-documents
MINIO_SECURE=false
