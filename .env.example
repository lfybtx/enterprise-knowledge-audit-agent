# local: deterministic test fallback; local-hf: downloads BAAI/bge-small-zh-v1.5 once.
MODEL_PROVIDER=local-hf
LOCAL_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
LOCAL_EMBEDDING_DIMENSIONS=512
MODEL_CACHE_DIR=/app/data/models
RERANKER_ENABLED=true
LOCAL_RERANKER_MODEL=BAAI/bge-reranker-base

# Set MODEL_PROVIDER=openai-compatible to prepare for the remote embedding and
# chat-model integrations in the next phase. Never commit a real key.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# The current pgvector schema is vector(512), so keep this at 512.
OPENAI_EMBEDDING_DIMENSIONS=512
POSTGRES_DB=enterprise_audit
POSTGRES_USER=audit_app
POSTGRES_PASSWORD=audit_app_dev
DATABASE_URL=postgresql+psycopg://audit_app:audit_app_dev@db:5432/enterprise_audit
