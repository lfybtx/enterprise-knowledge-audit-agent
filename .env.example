# Local development database settings. Do not use these values in production.
POSTGRES_DB=enterprise_audit
POSTGRES_USER=audit_app
POSTGRES_PASSWORD=audit_app_dev
DATABASE_URL=postgresql+psycopg://audit_app:audit_app_dev@db:5432/enterprise_audit

# Local model mode. The model cache is mounted at data/models.
MODEL_PROVIDER=local-hf
LOCAL_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
LOCAL_EMBEDDING_DIMENSIONS=512
MODEL_CACHE_DIR=/app/data/models

# Optional chat synthesis mode. Keep CHAT_PROVIDER=local for fully offline
# deterministic answers. To use Ollama from Docker, run
# `ollama pull qwen2.5:7b-instruct`, then set CHAT_PROVIDER=openai-compatible.
CHAT_PROVIDER=local
# CHAT_OPENAI_BASE_URL=http://host.docker.internal:11434/v1
# CHAT_OPENAI_API_KEY=ollama
# CHAT_OPENAI_MODEL=qwen2.5:7b-instruct

# Optional remote embedding provider. Leave unset when using local-hf.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=512

# MinIO object storage.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=audit-documents
MINIO_SECURE=false
